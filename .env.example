OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5
OPENAI_WIRE_API=chat
OPENAI_TIMEOUT_MS=120000
AUTH_COOKIE_SECURE=false

# Internal beta access and unified credit wallet.
BETA_REQUIRE_INVITE=false
BETA_MASTER_INVITE_CODES=
BETA_INITIAL_CREDITS=500
BETA_ENABLE_REFERRAL_REWARD=false
BETA_REFERRAL_CREDITS=0
BETA_ADMIN_EMAILS=
BETA_MAX_IMAGE_PAGES=10

REAL_SEARCH_ENABLED=true
PUBLIC_SEARCH_PROVIDER=bing

# REAL_SEARCH_ENABLED=true only enables the search pipeline. It does not mean an official provider is configured.
# Recommended official providers: tavily, serper, brave. The built-in keyless Bing HTML scraper is only
# experimental fallback (provider=bing -> runtime provider bing_html) and is not recommended for production evidence.
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
BING_SEARCH_API_KEY=

PUBLIC_SEARCH_TIMEOUT_MS=12000
PUBLIC_SEARCH_MAX_RESULTS=8
PUBLIC_SEARCH_MAX_CONTENT_CHARS=12000
PUBLIC_SEARCH_REQUIRE_URL=true
# Dedicated OpenAI-compatible image channel. Text-model credentials are not used here.
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.xcode.hk
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_ENDPOINT=/v1/images/generations
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_TIMEOUT_MS=240000
OPENAI_IMAGE_CONCURRENCY=3
OPENAI_IMAGE_MAX_IMAGES=4
