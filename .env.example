OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5
OPENAI_WIRE_API=chat
OPENAI_TIMEOUT_MS=120000

REAL_SEARCH_ENABLED=true
PUBLIC_SEARCH_PROVIDER=bing

# REAL_SEARCH_ENABLED=true only enables the search pipeline. It does not mean an official provider is configured.
# Recommended official providers: tavily, serper, brave. The built-in keyless Bing HTML scraper is only
# experimental fallback (provider=bing -> runtime provider bing_html) and is not recommended for production evidence.
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
BING_SEARCH_API_KEY=

PUBLIC_SEARCH_TIMEOUT_MS=12000
PUBLIC_SEARCH_MAX_RESULTS=8
PUBLIC_SEARCH_MAX_CONTENT_CHARS=12000
PUBLIC_SEARCH_REQUIRE_URL=true
PINCHUAN_API_BASE_URL=https://pinchuanapi.tech
PINCHUAN_API_KEY=
PINCHUAN_API_KEYS=
SANDUN_IMAGE_PROVIDER=pinchuan
SANDUN_IMAGE_MODEL=gpt-image-2
SANDUN_IMAGE_ENDPOINT=/v1/images/generations
SANDUN_IMAGE_MAX_IMAGES=4
SANDUN_IMAGE_CONCURRENCY=1
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
