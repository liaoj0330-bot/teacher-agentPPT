generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  passwordHash       String
  inviteCode         String              @unique
  invitedById        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           AuthSession[]
  coursewareProjects CoursewareProject[]
  credit             CreditAccount?
  creditLedger       CreditLedger[]
  pptSessions        PptSession[]
  sourceAssets       SourceAsset[]
  feedbackTickets    FeedbackTicket[]
}

model SourceAsset {
  id           String   @id
  userId       String
  fileName     String
  mimeType     String   @default("")
  fileType     String
  byteSize     Int
  sha256       String
  storagePath  String
  parseStatus  String   @default("pending")
  parser       String   @default("")
  analysisJson String   @default("{}")
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, sha256])
}

model AuthSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PptSession {
  id           String   @id @default(cuid())
  userId       String
  title        String
  prompt       String
  stage        String   @default("idle")
  provider     String?
  projectJson  String
  assetsJson   String   @default("[]")
  searchJson   String   @default("[]")
  visualsJson  String   @default("{}")
  messagesJson String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model CoursewareProject {
  id               String                  @id @default(cuid())
  userId           String
  title            String
  subject          String
  schoolStage      String
  grade            String
  currentVersionId String?
  lifecycleStatus  String                  @default("draft")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  artifacts        CoursewareArtifact[]
  chatMessages     CoursewareChatMessage[]
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests         CoursewareRequest[]
  versions         CoursewareVersion[]
  feedbackTickets  FeedbackTicket[]

  @@index([userId, updatedAt])
}

model CoursewareRequest {
  id                  String              @id @default(cuid())
  projectId           String
  requestType         String
  teacherTaskSnapshot String
  status              String              @default("pending")
  errorFacts          String?
  createdAt           DateTime            @default(now())
  completedAt         DateTime?
  project             CoursewareProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions            CoursewareVersion[]

  @@index([projectId, createdAt])
}

model CoursewareVersion {
  id                      String               @id @default(cuid())
  projectId               String
  requestId               String
  versionNumber           Int
  teacherTaskSnapshot     String
  contentPlanSnapshot     String               @default("{}")
  slidePagePlanSnapshot   String               @default("[]")
  layoutPlanSnapshot      String               @default("[]")
  evidenceSnapshot        String               @default("[]")
  deckSpecSnapshot        String               @default("{}")
  deckSpecHash            String               @default("")
  engineeringStatus       String               @default("pending")
  teacherReadiness        String               @default("pending")
  lifecycleStatus         String               @default("draft")
  createdAt               DateTime             @default(now())
  slideContentSnapshot    String               @default("[]")
  parentVersionId         String?
  operation               String               @default("initial_generate")
  summary                 String               @default("")
  idempotencyKey          String?
  sourceDocumentsSnapshot String               @default("[]")
  artifacts               CoursewareArtifact[]
  request                 CoursewareRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  project                 CoursewareProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbackTickets         FeedbackTicket[]

  @@unique([projectId, versionNumber])
  @@unique([projectId, idempotencyKey])
  @@index([projectId, createdAt])
}

model FeedbackTicket {
  id                 String             @id @default(cuid())
  userId             String
  projectId          String?
  versionId          String?
  subject            String             @default("")
  topic              String             @default("")
  pageNumber         Int?
  pageId             String?
  taskId             String?
  category           String
  severity           String             @default("P2")
  message            String
  clientMetadataJson String             @default("{}")
  status             String             @default("new")
  assignee           String?
  idempotencyKey     String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  resolvedAt         DateTime?
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            CoursewareProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version            CoursewareVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@unique([userId, idempotencyKey])
  @@index([userId, status, createdAt])
  @@index([projectId, createdAt])
  @@index([status, severity, createdAt])
}

model CoursewareChatMessage {
  id               String            @id @default(cuid())
  projectId        String
  versionId        String?
  role             String
  content          String
  status           String            @default("complete")
  suggestedActions String            @default("[]")
  suggestedPatch   String            @default("{}")
  appliedVersionId String?
  createdAt        DateTime          @default(now())
  project          CoursewareProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model CoursewareArtifact {
  id                 String            @id @default(cuid())
  projectId          String
  versionId          String
  artifactType       String
  status             String            @default("pending")
  storagePath        String            @default("")
  manifestJson       String            @default("{}")
  sourceDeckSpecHash String            @default("")
  sourceArtifactId   String?
  errorDetail        String?
  createdAt          DateTime          @default(now())
  version            CoursewareVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  project            CoursewareProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, versionId, artifactType])
}

model ImageGenerationJob {
  id             String    @id @default(cuid())
  ownerKey       String
  userId         String?
  idempotencyKey String
  requestJson    String    @default("{}")
  pagesJson      String    @default("[]")
  resultJson     String    @default("{}")
  status         String    @default("queued")
  errorMessage   String?
  attempts       Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  @@unique([ownerKey, idempotencyKey])
  @@index([ownerKey, updatedAt])
}
