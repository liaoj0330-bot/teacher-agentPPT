{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-069-e2e/types/**/*.ts",
    ".next-069-e2e/dev/types/**/*.ts",
    ".next-volcengine-test/types/**/*.ts",
    ".next-volcengine-test/dev/types/**/*.ts",
    ".next-volcengine-health/types/**/*.ts",
    ".next-volcengine-health/dev/types/**/*.ts",
    ".next-volcengine-deck/types/**/*.ts",
    ".next-volcengine-deck/dev/types/**/*.ts",
    ".next-volcengine-live/types/**/*.ts",
    ".next-volcengine-live/dev/types/**/*.ts",
    ".next-template-api-e2e/types/**/*.ts",
    ".next-template-api-e2e/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "outputs",
    "artifacts/backups/**",
    "dev-backup-*/**",
    "**/backup/**",
    "**/backups/**",
    "**/snapshot/**",
    "**/recovery/**"
  ]
}
